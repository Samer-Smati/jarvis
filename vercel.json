{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm ci --prefix backend && npm ci --prefix frontend",
  "buildCommand": "npm run build --prefix backend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist/frontend/browser",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "backend/dist/**,backend/node_modules/**,backend/node_modules/sql.js/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
