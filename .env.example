# LLM provider: lmstudio | ollama | claude | groq
LLM_PROVIDER=groq

# Groq — free cloud tier (web/mobile default): https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# LM Studio — best model on this PC: qwen/qwen3.5-9b
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_CHAT_MODEL=qwen/qwen3.5-9b
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Embeddings (uses LM Studio nomic embed)
EMBED_PROVIDER=lmstudio

# Ollama fallback — llama3.2 (2 GB, faster)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Claude (optional cloud)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Storage
DATABASE_PATH=data/jarvis.sqlite
FILES_ROOT=data/files

# Server
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Speech-to-text (local Whisper — multilingual incl. Tunisian Arabic)
WHISPER_MODEL=Xenova/whisper-small
TRANSFORMERS_CACHE=data/whisper-cache

# Text-to-speech (local Piper — neural, British JARVIS tone)
TTS_ENGINE=piper
PIPER_BIN=
PIPER_VOICE=en_GB-alan-medium
PIPER_CACHE=data/piper-cache

# Google Calendar (optional — OAuth refresh token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Home Assistant
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Coding sandbox
SANDBOX_ENABLED=true
SANDBOX_ROOT=data/sandbox
