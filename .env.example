# LLM provider: gemini | openrouter | groq | lmstudio | ollama | claude | xai
# Web/mobile (Vercel): gemini (best free tier) or openrouter or groq
LLM_PROVIDER=gemini

# Google Gemini — generous FREE tier (recommended for web/mobile)
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
GEMINI_FALLBACK_MODELS=gemini-2.0-flash,gemini-2.0-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# OpenRouter — one key, many free models (Kimi, DeepSeek, Qwen, Llama)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_FALLBACK_MODELS=google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
JARVIS_APP_URL=https://your-app.vercel.app
JARVIS_APP_NAME=JARVIS

# Groq — fast free tier: https://console.groq.com
# Default: llama-3.1-8b-instant (14,400 req/day free, always available)
# Fallback: llama-3.3-70b-versatile (better tools), gpt-oss-20b
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODELS=llama-3.3-70b-versatile,openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# xAI Grok — paid credits: https://console.x.ai
XAI_API_KEY=
XAI_MODEL=grok-3-fast
XAI_BASE_URL=https://api.x.ai/v1

# LM Studio — best model on this PC: qwen/qwen3.5-9b
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_CHAT_MODEL=qwen/qwen3.5-9b
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# Embeddings (uses LM Studio nomic embed)
EMBED_PROVIDER=lmstudio

# Ollama fallback — llama3.2 (2 GB, faster)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Claude (optional cloud)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Storage
DATABASE_PATH=data/jarvis.sqlite
FILES_ROOT=data/files

# Vercel cloud persistence (optional — enables server-side chat history on Vercel)
# Create a Blob store in Vercel project → Storage → Blob, then add BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=

# Server
PORT=3000
CORS_ORIGIN=http://localhost:4200

# Speech-to-text (local Whisper — multilingual incl. Tunisian Arabic)
WHISPER_MODEL=Xenova/whisper-small
TRANSFORMERS_CACHE=data/whisper-cache

# Text-to-speech (local Piper — neural, British JARVIS tone)
TTS_ENGINE=piper
PIPER_BIN=
PIPER_VOICE=en_US-lessac-medium
PIPER_CACHE=data/piper-cache

# Google Calendar (optional — OAuth refresh token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Home Assistant
HOME_ASSISTANT_URL=
HOME_ASSISTANT_TOKEN=

# Coding sandbox
SANDBOX_ENABLED=true
SANDBOX_ROOT=data/sandbox
