# JARVIS Backend — environment variables
# Copy to backend/.env and fill in values.

# --- LLM (pick one for cloud) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Persistent brain (recommended for Vercel) ---
# Neon PostgreSQL — free tier: https://neon.tech
# Use the *pooled* connection string (host contains -pooler)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Vercel Blob — brain wiki vault + conversation backup
BLOB_READ_WRITE_TOKEN=

# Gemini embeddings for cloud semantic memory (free tier)
GEMINI_EMBED_MODEL=text-embedding-004
EMBED_PROVIDER=gemini

# --- Desktop local AI (optional) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LMSTUDIO_EMBED_MODEL=text-embedding-nomic-embed-text-v1.5

# --- Local SQLite fallback (when DATABASE_URL is not set) ---
DATABASE_PATH=data/jarvis.sqlite

# --- Self-upgrade (GitHub + Vercel) ---
GITHUB_TOKEN=
GITHUB_REPO=Samer-Smati/jarvis
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=

# --- Integrations (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
OPENWEATHER_API_KEY=

# --- Serverless flags (set automatically on Vercel) ---
# VERCEL=1
# JARVIS_SERVERLESS=1
